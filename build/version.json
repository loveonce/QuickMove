const fs = require('fs');
const path = require('path');

// Path to your C# file (assuming version.js is placed in the same VSCode directory)
const filePath = path.join(__dirname, 'MainWindow.xaml.cs');

function bumpVersion(releaseType = 'patch') {
    if (!fs.existsSync(filePath)) {
        console.error(`❌ File not found: ${filePath}`);
        process.exit(1);
    }

    let content = fs.readFileSync(filePath, 'utf8');
    
    // Regex to find: public const string APP_VERSION = "1.0.3";
    const versionRegex = /(?:public|private) const string APP_VERSION = "(\d+)\.(\d+)\.(\d+)";/;
    const match = content.match(versionRegex);
    
    if (match) {
        let major = parseInt(match[1], 10);
        let minor = parseInt(match[2], 10);
        let patch = parseInt(match[3], 10);
        
        // Increment based on release type
        if (releaseType === 'major') {
            major++; minor = 0; patch = 0;
        } else if (releaseType === 'minor') {
            minor++; patch = 0;
        } else {
            patch++; // Default is patch
        }
        
        const newVersion = `${major}.${minor}.${patch}`;
        content = content.replace(versionRegex, `public const string APP_VERSION = "${newVersion}";`);
        
        fs.writeFileSync(filePath, content, 'utf8');
        console.log(`✅ Successfully bumped APP_VERSION to ${newVersion} in MainWindow.xaml.cs`);
    } else {
        console.error('❌ Version string not found in MainWindow.xaml.cs!');
        process.exit(1);
    }
}

// Get the release type from CLI arguments (e.g., node version.js minor)
const type = process.argv[2] || 'patch';
bumpVersion(type);
